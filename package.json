{
  "name": "guardpost",
  "version": "0.0.1",
  "description": "Permissions and audit logging for AI agents. Declare what your agent is allowed to do — guardpost enforces it and logs everything.",
  "keywords": [
    "ai",
    "agents",
    "permissions",
    "authorization",
    "audit",
    "llm",
    "mcp",
    "tool-use",
    "safety"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "demo": "tsx examples/demo.ts",
    "test": "tsx --test test/*.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
